---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";
import CustomButton from "./CustomButton.astro";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects">
  {
    projects.map(({ name, summary, image, wip, linkPreview, linkSources }, index) => {
      const top = 98 + index * 40;
      return (
        <div
          style={`top: ${top}px;`}
          class="sticky mb-12 rounded-2xl border border-neutral/20 bg-black"
        >
          <div class="bg-difu relative z-[1] grid h-[580px] w-full grid-rows-2 rounded-2xl bg-[#1c232d]/85 before:absolute before:inset-0 before:z-[-1] before:rounded-2xl  before:bg-[length:128px] before:bg-repeat before:opacity-[5%] before:content-[''] sm:grid-cols-2 sm:grid-rows-1 md:h-96">
            <div class="px-6 pt-12">
              <div class="mb-5 flex items-center gap-3">
                <h3 class="font-serif text-3xl font-medium text-primary">
                  {name}
                </h3>
                {wip && (
                  <span class="rounded-full border border-yellow-500/40 bg-yellow-500/10 px-3 py-1 text-xs text-yellow-400">
                    Work in Progress
                  </span>
                )}
              </div>
              <p class="text-base text-neutral">{summary}</p>
              <div class="flex gap-5 pt-10 text-white">
                {linkSources?.map(({ label, href }) => (
                  <a
                    href={href}
                    target="_blank"
                    class="after:relative after:bottom-[-5px] after:content-[url(external.svg)] hover:underline"
                  >
                    {label}
                  </a>
                ))}
                {linkPreview && (
                  <a
                    href={linkPreview}
                    target="_blank"
                    class="after:relative after:bottom-[-5px] after:content-[url(external.svg)] hover:underline"
                  >
                    Preview
                  </a>
                )}
              </div>
            </div>
            <div class="flex items-center justify-center overflow-hidden p-8">
              <img
                class="max-h-48 w-auto object-contain"
                src={image}
                alt={name}
              />
            </div>
          </div>
        </div>
      );
    })
  }
  <div class="mt-4">
    <p class="mb-12 text-base text-neutral">
       I have written three case studies on specific problems I encountered at Monster Property Services.
    </p>
    <CustomButton href="/case-studies" innerText="View Case Studies" />
  </div>
</Section>
