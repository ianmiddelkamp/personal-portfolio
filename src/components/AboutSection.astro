---
// AboutSection.astro
import type { AboutPageProps } from "@types";
import { Image } from "astro:assets";
import profileImg from "../../public/profile-big.jpg";
import "../styles/global.css";
import Section from "./Section.astro";

type Props = AboutPageProps;

const data = Astro.props;
---

<Section text="About Me">
    <h1 class="mb-6 text-4xl font-bold text-primary"></h1>
    <div class="mb-10 flex flex-col items-center gap-8">
        <Image
            class="w-auto object-cover"
            src={data.mainImage.src}
            width={data.mainImage.width}
            height={data.mainImage.height}
            alt={data.mainImage.name}
        />
    </div>

    <div>
        <p class="mb-2 text-base text-neutral">{data.intro}</p>
    </div>

    {
        data.sections.map(({ title, description, images }) => (
            <div class="mb-10">
                <div class="flex flex-col items-center gap-8">
                    <h2 class="self-start text-xl font-bold text-white">
                        {title}
                    </h2>
                    <p class="w-auto text-base text-neutral md:pr-5">
                        {description}
                    </p>
                    {images.length > 0 && (
                        <div class="flex flex-row flex-wrap justify-center gap-12">
                            {images.map((image, index) => (
                                <div
                                    class={`thumbnail flex-shrink-0 bg-white flex-shrink-1 p-1 flex flex-row items-center`}
                                    data-fullsrc={image.src}
                                    data-alt={image.name}
                                >
                                    <Image
                                        class="object-cover"
                                        src={image.thumbSrc || image.src}
                                        width={image.width}
                                        height={image.height}
                                        alt={image.name}
                                    />
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            </div>
        ))
    }
    <!-- Overlay Structure -->
    <div id="overlay">
        <div class="overlay-container bg-white p-1">
            <img class='max-w-[90vw] sm:max-w-[90vw] md:max-w-[90vw]' alt="Enlarged view" />
        </div>
    </div>
</Section>

<script>


    const cancelOverlay = () => {
        const overlay = document.getElementById("overlay");
        if (overlay) {
            const overlayImg = overlay.querySelector("img");
            if (overlayImg) {
                overlayImg.setAttribute("src", ""); //clear image
            }
            overlay.style.display = "none";
            overlay.removeAttribute("data-loading");
        }
    };

    // Add click event listeners to thumbnails
    document.querySelectorAll(".thumbnail").forEach((thumbnail) => {
        thumbnail.addEventListener("click", (event) => {
          
            const element = event.currentTarget as HTMLElement;
            const imgSrc = element.getAttribute("data-fullsrc");
            const imgAlt = element.getAttribute("data-alt");
            const overlay = document.getElementById("overlay");
            if (!overlay) return;
            if(overlay.getAttribute("data-loading")) return; // Prevent multiple clicks while loading
            overlay.setAttribute("data-loading", "true");
            const overlayImg = overlay.querySelector("img");
            if (overlayImg && imgSrc) {
                const image = new window.Image();
                image.src = imgSrc;
                image.onload = () => {
                    overlayImg.setAttribute("src", imgSrc);
                    overlayImg.setAttribute("alt", imgAlt || "Enlarged image");
                    overlay.style.display = "flex";
                    overlay.removeAttribute("data-loading");
                };
                image.onerror = () => {
                    cancelOverlay();
                   
                };
            }
        });
    });
    document.getElementById("overlay")?.addEventListener("click", cancelOverlay);
</script>

<style>
    #overlay {
        display: none; /* Hidden by default */
        position: fixed;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
        z-index: 999;
        cursor: pointer;
        justify-content: center;
        align-items: center;
    }
    .overlay-container {
        position: fixed;
        top: 50%;
        left: 50%; 
        flex-shrink: 1;
        transform: translate(-50%, -50%);
    }
</style>
